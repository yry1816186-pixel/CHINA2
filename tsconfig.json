{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "src/main.tsx",
    "src/app/App.tsx",
    "src/app/index.ts",
    "src/app/types/**/*.ts",
    "src/app/context/**/*.ts",
    "src/app/context/**/*.tsx",
    "src/app/pages/**/*.tsx",
    "src/app/data/**/*.ts",
    "src/app/components/ErrorBoundary.tsx",
    "src/app/components/site/**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/app/modules/**/*",
    "src/app/components/ui/**/*",
    "src/app/components/examples/**/*",
    "src/app/components/shared/**/*",
    "src/app/components/FirstTimeGuide.tsx",
    "src/app/components/LoadingIndicator.tsx",
    "src/app/components/LoadingScreen.tsx",
    "src/app/components/Toast.tsx",
    "src/app/data.ts"
  ]
}

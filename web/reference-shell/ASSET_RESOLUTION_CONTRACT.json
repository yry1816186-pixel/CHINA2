{
  "id": "china2-first-wave-asset-resolution-contract",
  "version": "0.1.0",
  "status": "controlled_first_wave_not_final",
  "pageEntry": "web/reference-shell/index.contract.html",
  "dropzoneRootFromReferenceShell": "../assets/first-wave/",
  "resolutionPolicy": {
    "goal": "allow agent-side intake from a single dropzone without pushing manifest editing back to the user",
    "preferVideo": true,
    "fallbackToPoster": true,
    "neverUpgradeIntroToFrozenEntry": true,
    "notes": [
      "This contract does not claim automatic resolution is already fully implemented in every shell.",
      "It defines the canonical mapping that future shell code must inherit.",
      "If both manifest fields and dropzone files exist, shell behavior should prefer the stricter canonical mapping rather than ad hoc guessing."
    ]
  },
  "requiredCoreScenes": [
    {
      "sceneId": "scene_03_structure_primary",
      "video": "scene_03_structure_primary.mp4",
      "posters": [
        "scene_03_structure_primary.jpg",
        "scene_03_structure_primary.png",
        "scene_03_structure_primary.webp"
      ],
      "handoffTier": "core_first_wave"
    },
    {
      "sceneId": "scene_06_conservation_boundary",
      "video": "scene_06_conservation_boundary.mp4",
      "posters": [
        "scene_06_conservation_boundary.jpg",
        "scene_06_conservation_boundary.png",
        "scene_06_conservation_boundary.webp"
      ],
      "handoffTier": "core_first_wave"
    },
    {
      "sceneId": "scene_01_orientation_order",
      "video": "scene_01_orientation_order.mp4",
      "posters": [
        "scene_01_orientation_order.jpg",
        "scene_01_orientation_order.png",
        "scene_01_orientation_order.webp"
      ],
      "handoffTier": "core_first_wave"
    }
  ],
  "exploratoryOnly": [
    {
      "sceneId": "scene_00_intro_entry",
      "video": "scene_00_intro_entry.mp4",
      "posters": [
        "scene_00_intro_entry.jpg",
        "scene_00_intro_entry.png",
        "scene_00_intro_entry.webp"
      ],
      "policy": "disclosure_first_threshold_test_only"
    }
  ],
  "agentMustKeepVisible": [
    "scene status",
    "evidence grade",
    "anchor boundary",
    "allowed mode",
    "misreading risk",
    "unresolved or reviewed_candidate disclosure"
  ],
  "agentMustNotPushBackToUser": [
    "manual manifest editing",
    "manual scene-to-file matching",
    "manual page-entry choice",
    "manual handoff package stitching"
  ],
  "knownOpenBlockers": [
    "The repository root default page still does not fully collapse into the contract-driven shell.",
    "Automatic dropzone resolution still needs implementation-level adoption in current shell code."
  ]
